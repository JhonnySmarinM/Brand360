# Brand360 - IA
# Copia a .env: cp .env.example .env

# OPCIÓN 1 - Gemini (Más fácil, funciona con npm run dev):
# VITE_AI_PROVIDER=gemini
# VITE_AI_API_KEY=tu_clave_gemini
# Obtén clave en: https://aistudio.google.com/apikey

# OPCIÓN 2 - Hugging Face (requiere: npm run dev:api, no npm run dev):
# VITE_AI_PROVIDER=huggingface
# HUGGING_FACE_API_KEY=hf_tu_api_key
